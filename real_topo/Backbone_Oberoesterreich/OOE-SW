crypto key gen rsa g m 1024

line con 0
login local
logging sync
exec-timeout 0

line vty 0 924
login local
logging sync
exec-timeout 0
transport input ssh telnet

vlan 201
name VLAN201

vlan 202
name VLAN202

vlan 203
name VLAN203

vlan 204
name VLAN204

vlan 210
name VLAN210

vlan 220
name VLAN220

vlan 502
name VLAN502

vlan 505
name VLAN505

vlan 506
name VLAN506

vlan 507
name VLAN507

