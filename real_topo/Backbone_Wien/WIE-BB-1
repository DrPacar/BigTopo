en
conf t
hostname WIE-BB-1
banner motd #DiagNet WAN Topology#
service password-encryption
no ip domain lookup

username cisco secret cisco
username cisco priv 15

ip domain-name diagnet.dev
ip ssh version 2
crypto key gen rsa g m 1024

line con 0
login local
logging sync
exec-timeout 0

line vty 0 924
login local
logging sync
exec-timeout 0
transport input ssh telnet

# Interfaces
int lo0
 ip address 10.10.255.1 255.255.255.255
 ipv6 enable
 no shut

int g0/0
no shut


int g0/0.155
encapsulation dot1q 155
ip address 10.10.1.2 255.255.255.0
ipv6 enable
no shut
desc to_POP1

int g0/0.156
encapsulation dot1q 156
ip address 10.10.2.2 255.255.255.0
ipv6 enable
no shut
desc to_POP2

int g0/0.153
encapsulation dot1q 153
ip address 10.10.6.1 255.255.255.0
 ipv6 enable
 no shut
desc to_BB2_1

int g0/0.154
encapsulation dot1q 154
ip address 10.10.3.1 255.255.255.0
 ipv6 enable
 no shut
desc to_BB2_2

# SNMP
ip access-list standard ACL_SNMP_SERVER
 permit 10.10.254.1
 exit
snmp-server view VIEW_RW iso included
snmp-server group GROUP_RW v3 priv read VIEW_RW write VIEW_RW access ACL_SNMP_SERVER
snmp-server user bigtopo123 GROUP_RW v3 auth sha bigtopo123 priv aes 128 bigtopo123

# AP 2.3 - Syslog Konfiguration
service timestamps log datetime msec
logging host 10.10.254.10
logging trap informational
logging source-interface Loopback0

# AP 2.1 - OSPFv2 Underlay (authenticated)

key chain WIE_OSPF_KC
 key 1
  key-string diagnet123
  cryptographic-algorithm hmac-sha-256

router ospf 1
 router-id 10.10.255.1
 area 0 authentication message-digest

int lo0
 ip ospf 1 area 0
 ip ospf network point-to-point
 ip ospf message-digest-key 1 md5 diagnet123

int g0/0.156
 ip ospf 1 area 0
 ip ospf network point-to-point
 ip ospf message-digest-key 1 md5 diagnet123

int g0/0.153
 ip ospf 1 area 0
 ip ospf network point-to-point
 ip ospf message-digest-key 1 md5 diagnet123

int g0/0.154
 ip ospf 1 area 0
 ip ospf network point-to-point
 ip ospf message-digest-key 1 md5 diagnet123

int g0/0.153
 ip ospf 1 area 0
 ip ospf network point-to-point
 ip ospf message-digest-key 1 md5 diagnet123

# AP 2.1 - IPsec fuer DMVPN
crypto isakmp policy 10
 encryption aes
 hash sha
 authentication pre-share
 group 2
 lifetime 86400
crypto isakmp key dmvpn123 address 0.0.0.0

crypto ipsec transform-set DMVPN_TSET esp-aes esp-sha-hmac
 mode transport

crypto ipsec profile DMVPN_PROFILE
 set transform-set DMVPN_TSET

# AP 2.1 - DMVPN Hub Cloud 1
int tunnel 1
 description DMVPN-Hub-Cloud1
 ip address 10.10.100.1 255.255.255.0
 no shut
 tunnel source lo0
 tunnel mode gre multipoint
 tunnel protection ipsec profile DMVPN_PROFILE
 ip nhrp network-id 1
 ip nhrp authentication dmvpn123
 ip nhrp map multicast dynamic
 ip nhrp redirect
 no ip split-horizon eigrp 100
 no ip next-hop-self eigrp 100

# AP 2.1 - EIGRP Overlay (Loopback-Exchange via DMVPN)
router eigrp 100
 network 10.10.100.0 0.0.0.255
 no auto-summary
