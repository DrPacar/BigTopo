en
conf t
hostname WIE-BB-2
banner motd #DiagNet WAN Topology#
service password-encryption
no ip domain lookup

username cisco secret cisco
username cisco priv 15

ip domain-name diagnet.dev
ip ssh version 2
crypto key gen rsa g m 1024

line con 0
login local
logging sync
exec-timeout 0

line vty 0 924
login local
logging sync
exec-timeout 0
transport input ssh telnet

# Interfaces
int lo0
 ip address 10.10.255.2 255.255.255.255
 ipv6 enable
 no shut

int f0/0
no shut

int f0/0.152
ip address 10.10.5.2 255.255.255.0
 ipv6 enable
 no shut
desc to_POP3

int f0/0.151
ip address 10.10.4.2 255.255.255.0
 ipv6 enable
 no shut
desc to_POP4

int f0/0.153
 ip address 10.10.6.2 255.255.255.0
 ipv6 enable
 no shut
desc to_BB1_1

int f0/0.154
 ip address 10.10.3.2 255.255.255.0
 ipv6 enable
 no shut
desc to_BB1_2

# SNMP
ip access-list standard ACL_SNMP_SERVER
 permit 10.10.254.1
 exit
snmp-server view VIEW_RW iso included
snmp-server group GROUP_RW v3 priv read VIEW_RW write VIEW_RW access ACL_SNMP_SERVER
snmp-server user bigtopo123 GROUP_RW v3 auth sha bigtopo123 priv aes 128 bigtopo123

# AP 2.3 - Syslog Konfiguration
service timestamps log datetime msec
logging host 10.10.254.10
logging trap informational
logging source-interface Loopback0

# AP 2.1 - OSPFv2 Underlay (authenticated)

key chain WIE_OSPF_KC
 key 1
  key-string diagnet123
  cryptographic-algorithm hmac-sha-256

router ospf 1
 router-id 10.10.255.2
 area 0 authentication message-digest
 bfd all-interfaces

int lo0
 ip ospf 1 area 0
 ip ospf network point-to-point
 ip ospf message-digest-key 1 md5 diagnet123

int f0/0.151
 encapsulation dot1q 151
 ip ospf 1 area 0
 ip ospf network point-to-point
 ip ospf message-digest-key 1 md5 diagnet123

int f0/0.152
 encapsulation dot1q 152
 ip ospf 1 area 0
 ip ospf network point-to-point
 ip ospf message-digest-key 1 md5 diagnet123

int f0/0.153
encapsulation dot1q 153
 ip ospf 1 area 0
 ip ospf network point-to-point
 ip ospf message-digest-key 1 md5 diagnet123

int f0/0.154
encapsulation dot1q 154
 ip ospf 1 area 0
 ip ospf network point-to-point
 ip ospf message-digest-key 1 md5 diagnet123
