en
conf t
hostname WIE-POP-2
banner motd #DiagNet WAN Topology#
service password-encryption
no ip domain lookup

username cisco secret cisco
username cisco priv 15

ip domain-name diagnet.dev
ip ssh version 2
crypto key gen rsa g m 1024

line con 0
login local
logging sync
exec-timeout 0

line vty 0 924
login local
logging sync
exec-timeout 0
transport input ssh telnet

# Interfaces
int lo0
 ip address 10.10.255.12 255.255.255.255
 ipv6 enable
 no shut

int gig0/0
 ip address 172.16.5.254 255.255.255.0
 ipv6 enable
 no shut

int gig0/1
 ip address 10.10.2.1 255.255.255.0
 ipv6 enable
 no shut

# SNMP
ip access-list standard ACL_SNMP_SERVER
 permit 10.10.254.1
 exit
snmp-server view VIEW_RO iso included
snmp-server group GROUP_RO v3 priv read VIEW_RO access ACL_SNMP_SERVER
snmp-server user bigtopo123 GROUP_RO v3 auth sha bigtopo123 priv aes 128 bigtopo123

# AP 2.1 - OSPFv3 Underlay (authenticated)
ipv6 unicast-routing

key chain WIE_OSPF_KC
 key 1
  key-string diagnet123
  cryptographic-algorithm hmac-sha-256

router ospfv3 1
 router-id 10.10.255.12
 address-family ipv4 unicast
  area 0 authentication key-chain WIE_OSPF_KC

int lo0
 ospfv3 1 ipv4 area 0
 ospfv3 1 ipv4 network point-to-point

int gig0/1
 ospfv3 1 ipv4 area 0
 ospfv3 1 ipv4 network point-to-point

# AP 2.2 - BGP RR-Client
router bgp 3
 bgp router-id 10.10.255.12
 bgp log-neighbor-changes
 neighbor 10.10.255.11 remote-as 3
 neighbor 10.10.255.11 update-source lo0
 neighbor 10.10.255.13 remote-as 3
 neighbor 10.10.255.13 update-source lo0
 !
 address-family ipv4
  neighbor 10.10.255.11 activate
  neighbor 10.10.255.13 activate
