en
conf t
hostname WIE-BB-1
banner motd #DiagNet WAN Topology#
service password-encryption
no ip domain lookup

username cisco secret cisco
username cisco priv 15

ip domain-name diagnet.dev
ip ssh version 2
crypto key gen rsa g m 1024

line con 0
login local
logging sync
exec-timeout 0

line vty 0 924
login local
logging sync
exec-timeout 0
transport input ssh telnet

# Interfaces
int lo0
 ip address 10.10.255.1 255.255.255.255
 no shut

int gig0/0
 ip address 10.10.1.2 255.255.255.0
 no shut

int gig0/1
 ip address 10.10.2.2 255.255.255.0
 no shut

int gig0/2
 ip address 10.10.6.1 255.255.255.0
 no shut

int gig0/3
 ip address 10.10.3.1 255.255.255.0
 no shut

# SNMP
ip access-list standard ACL_SNMP_SERVER
 permit 10.10.254.1
 exit
configure terminal

snmp-server view VIEW_RW iso included
snmp-server group GROUP_RW v3 priv read VIEW_RW write VIEW_RW access ACL_SNMP_SERVER
snmp-server user bigtopo123 GROUP_RW v3 auth sha bigtopo123 priv aes 128 bigtopo123

# AP 2.1 - OSPFv3 Underlay (authenticated, BFD)
key chain WIE_OSPF_KC
 key 1
  key-string diagnet123
  cryptographic-algorithm hmac-sha-256

router ospfv3 1
 router-id 10.10.255.1
 bfd all-interfaces
 address-family ipv4 unicast
  area 0 authentication key-chain WIE_OSPF_KC

int lo0
 ospfv3 1 ipv4 area 0
 ospfv3 1 ipv4 network point-to-point

int gig0/0
 bfd interval 50 min_rx 50 multiplier 3
 ospfv3 1 ipv4 area 0
 ospfv3 1 ipv4 network point-to-point

int gig0/1
 bfd interval 50 min_rx 50 multiplier 3
 ospfv3 1 ipv4 area 0
 ospfv3 1 ipv4 network point-to-point

int gig0/2
 bfd interval 50 min_rx 50 multiplier 3
 ospfv3 1 ipv4 area 0
 ospfv3 1 ipv4 network point-to-point

int gig0/3
 bfd interval 50 min_rx 50 multiplier 3
 ospfv3 1 ipv4 area 0
 ospfv3 1 ipv4 network point-to-point

# AP 2.1 - IPsec fuer DMVPN
crypto isakmp policy 10
 encryption aes 256
 hash sha256
 authentication pre-share
 group 14
 lifetime 3600
crypto isakmp key dmvpn123 address 0.0.0.0

crypto ipsec transform-set DMVPN_TSET esp-aes 256 esp-sha256-hmac
 mode transport

crypto ipsec profile DMVPN_PROFILE
 set transform-set DMVPN_TSET

# AP 2.1 - DMVPN Hub Cloud 1
int tunnel 1
 description DMVPN-Hub-Cloud1
 ip address 10.10.100.1 255.255.255.0
 no shut
 tunnel source lo0
 tunnel mode gre multipoint
 tunnel key 1
 tunnel protection ipsec profile DMVPN_PROFILE
 ip nhrp network-id 1
 ip nhrp authentication dmvpn123
 ip nhrp map multicast dynamic

# AP 2.1 - EIGRP Overlay (Loopback-Exchange via DMVPN)
router eigrp DMVPN_OVERLAY
 address-family ipv4 unicast autonomous-system 100
  af-interface tunnel 1
   no split-horizon
   no next-hop-self
  exit-af-interface
  distance eigrp 115 115
  network 10.10.100.0 0.0.0.255
  network 10.10.255.0 0.0.0.255

# AP 2.2 - WIE-BB-1 ist reiner OSPFv3/DMVPN Core-Router (P-Router)
# BGP nicht benoetigt - Loopback-Erreichbarkeit via OSPFv3 + EIGRP im DMVPN
